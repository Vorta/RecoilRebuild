{
  "name": "zvideo_primary_blit_directdraw",
  "description": "zVideo primary-surface blit clipping and DirectDraw surface lock/unlock helpers.",
  "source_filename": "zVideo_PrimaryBlitDirectDraw.cpp",
  "source": [
    "#define RECOIL_FASTCALL __fastcall",
    "#define RECOIL_NOINLINE",
    "#define DD_OK 0",
    "#define DDERR_SURFACELOST ((long)0x887601c2)",
    "#define DDLOCK_WAIT 0x00000001",
    "#define DDBLT_WAIT 0x01000000",
    "#define DDBLT_KEYSRCOVERRIDE 0x00000200",
    "",
    "typedef long HRESULT;",
    "typedef unsigned long DWORD;",
    "",
    "struct RECT {",
    "    long left;",
    "    long top;",
    "    long right;",
    "    long bottom;",
    "};",
    "",
    "struct DDSURFACEDESC {",
    "    DWORD dwSize;",
    "    DWORD dwFlags;",
    "    DWORD dwHeight;",
    "    DWORD dwWidth;",
    "    long lPitch;",
    "    DWORD dwBackBufferCount;",
    "    DWORD dwMipMapCount;",
    "    DWORD dwAlphaBitDepth;",
    "    DWORD dwReserved;",
    "    void *lpSurface;",
    "    unsigned char reserved_28[0x44];",
    "};",
    "",
    "struct IDirectDrawSurface3;",
    "typedef HRESULT (__stdcall *zVideo_SurfaceBltProc)(IDirectDrawSurface3 *, RECT *, IDirectDrawSurface3 *, RECT *, DWORD, void *);",
    "typedef HRESULT (__stdcall *zVideo_SurfaceLockProc)(IDirectDrawSurface3 *, RECT *, DDSURFACEDESC *, DWORD, void *);",
    "typedef HRESULT (__stdcall *zVideo_SurfaceRestoreProc)(IDirectDrawSurface3 *);",
    "typedef HRESULT (__stdcall *zVideo_SurfaceUnlockProc)(IDirectDrawSurface3 *, void *);",
    "",
    "struct zVideo_DirectDrawSurface3VtblPartial {",
    "    void *entries_00[5];",
    "    zVideo_SurfaceBltProc Blt;",
    "    void *entries_18[19];",
    "    zVideo_SurfaceLockProc Lock;",
    "    void *ReleaseDC;",
    "    zVideo_SurfaceRestoreProc Restore;",
    "    void *entries_70[4];",
    "    zVideo_SurfaceUnlockProc Unlock;",
    "};",
    "",
    "struct IDirectDrawSurface3 {",
    "    zVideo_DirectDrawSurface3VtblPartial *lpVtbl;",
    "};",
    "",
    "struct zVidRect32 {",
    "    int left;",
    "    int top;",
    "    int right;",
    "    int bottom;",
    "};",
    "",
    "struct zVidImagePartial {",
    "    void *pixels;",
    "    short width;",
    "    short height;",
    "    unsigned char unknown_08;",
    "    unsigned char formatFlagsPacked;",
    "    unsigned char reserved_0a[0x26];",
    "    IDirectDrawSurface3 *surface;",
    "};",
    "",
    "struct zVideo_SurfaceStatePartial {",
    "    int width;",
    "    int height;",
    "    int pitch;",
    "    int lockInfoValid;",
    "    void *pixels;",
    "    int locked;",
    "    int pageLockActive;",
    "    IDirectDrawSurface3 *surf;",
    "};",
    "",
    "namespace zRndr {",
    "void *g_frameBuffer = 0;",
    "}",
    "",
    "int g_zVideo_FullscreenOption = 0;",
    "zVideo_SurfaceStatePartial g_zVideo_PrimarySurfaceState = {0};",
    "zVideo_SurfaceStatePartial g_zVideo_DisplayModeSurfaceState = {0};",
    "typedef void (RECOIL_FASTCALL *zVideo_BltSourceToPrimaryProc)(zVidImagePartial *, int, int, int, zVidRect32 *);",
    "zVideo_BltSourceToPrimaryProc g_zVideo_pfnBltSourceToPrimary = 0;",
    "",
    "namespace zVideo {",
    "// Reimplements 0x4a67f0: zVideo::GetPrimarySurfacePixels",
    "RECOIL_NOINLINE void *__cdecl GetPrimarySurfacePixels() {",
    "    return g_zVideo_PrimarySurfaceState.pixels;",
    "}",
    "}",
    "",
    "namespace zVideo_dd {",
    "RECOIL_NOINLINE int RECOIL_FASTCALL ReportError(int hresult, const char *sourceFile, int sourceLine);",
    "",
    "// Reimplements 0x4a8060: zVideo_dd::LockDirectDrawSurface",
    "RECOIL_NOINLINE int RECOIL_FASTCALL LockDirectDrawSurface(IDirectDrawSurface3 *surface,",
    "                                                         DDSURFACEDESC *outLockedSurfaceDesc) {",
    "    unsigned long *clearWords = (unsigned long *)outLockedSurfaceDesc;",
    "    for (int index = 0x1b; index > 0; --index) {",
    "        *clearWords++ = 0;",
    "    }",
    "    outLockedSurfaceDesc->dwSize = sizeof(*outLockedSurfaceDesc);",
    "",
    "    for (;;) {",
    "        zVideo_DirectDrawSurface3VtblPartial *vtable = surface->lpVtbl;",
    "        HRESULT hresult = vtable->Lock(surface, 0, outLockedSurfaceDesc, DDLOCK_WAIT, 0);",
    "        if (hresult == DD_OK) {",
    "            return 0;",
    "        }",
    "",
    "        if (hresult == DDERR_SURFACELOST) {",
    "            zVideo_DirectDrawSurface3VtblPartial *vtable = surface->lpVtbl;",
    "            hresult = vtable->Restore(surface);",
    "        }",
    "        if (hresult == DD_OK) {",
    "            continue;",
    "        }",
    "",
    "        ReportError((int)hresult, \"D:\\\\Proj\\\\GameZRecoil\\\\zVideo\\\\zvid_dd.c\", 0x1b9);",
    "        return 0x5a56ffff;",
    "    }",
    "}",
    "",
    "// Reimplements 0x4a80c0: zVideo_dd::UnlockDirectDrawSurface",
    "RECOIL_NOINLINE int RECOIL_FASTCALL UnlockDirectDrawSurface(IDirectDrawSurface3 *surface) {",
    "    for (;;) {",
    "        zVideo_DirectDrawSurface3VtblPartial *vtable = surface->lpVtbl;",
    "        HRESULT hresult = vtable->Unlock(surface, 0);",
    "        if (hresult == DD_OK) {",
    "            return 0;",
    "        }",
    "",
    "        if (hresult == DDERR_SURFACELOST) {",
    "            zVideo_DirectDrawSurface3VtblPartial *vtable = surface->lpVtbl;",
    "            hresult = vtable->Restore(surface);",
    "        }",
    "        if (hresult == DD_OK) {",
    "            continue;",
    "        }",
    "",
    "        ReportError((int)hresult, \"D:\\\\Proj\\\\GameZRecoil\\\\zVideo\\\\zvid_dd.c\", 0x1d7);",
    "        return 0x5a56ffff;",
    "    }",
    "}",
    "",
    "// Reimplements 0x4a7fc0: zVideo_dd::LockSurfaceState",
    "RECOIL_NOINLINE int RECOIL_FASTCALL LockSurfaceState(zVideo_SurfaceStatePartial *surfaceState) {",
    "    if (g_zVideo_FullscreenOption != 0) {",
    "        goto CheckLocked;",
    "    }",
    "    if (surfaceState != &g_zVideo_DisplayModeSurfaceState) {",
    "        goto CheckLocked;",
    "    }",
    "    return 0;",
    "",
    "CheckLocked:",
    "    if (surfaceState->locked != 0) {",
    "        return 0;",
    "    }",
    "",
    "    DDSURFACEDESC lockedSurfaceDesc;",
    "    const int result = LockDirectDrawSurface(surfaceState->surf, &lockedSurfaceDesc);",
    "    if (result == 0) {",
    "        const int locked = 1;",
    "        surfaceState->width = (int)lockedSurfaceDesc.dwWidth;",
    "        surfaceState->locked = locked;",
    "        surfaceState->height = (int)lockedSurfaceDesc.dwHeight;",
    "        surfaceState->lockInfoValid = locked;",
    "        surfaceState->pitch = (int)lockedSurfaceDesc.lPitch;",
    "        surfaceState->pixels = lockedSurfaceDesc.lpSurface;",
    "    }",
    "",
    "    return result;",
    "}",
    "",
    "// Reimplements 0x4a8030: zVideo_dd::UnlockSurfaceState",
    "RECOIL_NOINLINE int RECOIL_FASTCALL UnlockSurfaceState(zVideo_SurfaceStatePartial *surfaceState) {",
    "    if (g_zVideo_FullscreenOption != 0) {",
    "        goto CheckLocked;",
    "    }",
    "    if (surfaceState != &g_zVideo_DisplayModeSurfaceState) {",
    "        goto CheckLocked;",
    "    }",
    "    return 0;",
    "",
    "CheckLocked:",
    "    if (surfaceState->locked == 0) {",
    "        return 0;",
    "    }",
    "",
    "    surfaceState->locked = 0;",
    "    return UnlockDirectDrawSurface(surfaceState->surf);",
    "}",
    "} // namespace zVideo_dd",
    "",
    "namespace zVideo_buff {",
    "// Reimplements 0x4a69c0: zVideo_buff::ClipCoordToRange",
    "RECOIL_NOINLINE int RECOIL_FASTCALL ClipCoordToRange(int *coordPtr, int minCoord, int maxCoord) {",
    "    const int coord = *coordPtr;",
    "    int clipped = 0;",
    "    if (coord < minCoord) {",
    "        clipped = coord - minCoord;",
    "        *coordPtr = minCoord;",
    "    } else if (coord > maxCoord) {",
    "        clipped = coord - maxCoord;",
    "        *coordPtr = maxCoord;",
    "    }",
    "",
    "    return clipped;",
    "}",
    "",
    "// Reimplements 0x4a69e0: zVideo_buff::BltSourceToPrimaryClipped",
    "RECOIL_NOINLINE void RECOIL_FASTCALL BltSourceToPrimaryClipped(zVidImagePartial *srcImage,",
    "                                                               int dstX, int dstY,",
    "                                                               int srcColorKeyEnable,",
    "                                                               zVidRect32 *srcRect) {",
    "    zVidRect32 srcRectLocal;",
    "    int srcX;",
    "    int srcY;",
    "    int srcRight;",
    "    int srcBottom;",
    "    if (srcRect != 0) {",
    "        srcX = srcRect->left;",
    "        srcY = srcRect->top;",
    "        srcRight = srcRect->right;",
    "        srcBottom = srcRect->bottom;",
    "        srcRectLocal.left = srcX;",
    "        srcRectLocal.top = srcY;",
    "        srcRectLocal.right = srcRight;",
    "    } else {",
    "        srcRight = srcImage->width;",
    "        srcBottom = srcImage->height;",
    "        srcX = 0;",
    "        srcY = 0;",
    "        srcRectLocal.left = srcX;",
    "        srcRectLocal.top = srcY;",
    "        srcRectLocal.right = srcRight;",
    "    }",
    "",
    "    srcRectLocal.bottom = srcBottom;",
    "",
    "    zVidRect32 dstRectLocal;",
    "    dstRectLocal.left = dstX;",
    "    dstRectLocal.top = dstY;",
    "    dstRectLocal.right = srcRight - srcX + dstX;",
    "    dstRectLocal.bottom = srcBottom - srcY + dstY;",
    "",
    "    int clipped = ClipCoordToRange(&dstRectLocal.left, 0, g_zVideo_PrimarySurfaceState.width - 1);",
    "    if (clipped < 0) {",
    "        srcRectLocal.left -= clipped;",
    "    } else if (clipped > 0) {",
    "        return;",
    "    }",
    "",
    "    clipped = ClipCoordToRange(&dstRectLocal.right, 0, g_zVideo_PrimarySurfaceState.width);",
    "    if (clipped < 0) {",
    "        return;",
    "    }",
    "    if (clipped > 0) {",
    "        srcRectLocal.right -= clipped;",
    "    }",
    "",
    "    clipped = ClipCoordToRange(&dstRectLocal.top, 0, g_zVideo_PrimarySurfaceState.height - 1);",
    "    if (clipped < 0) {",
    "        srcRectLocal.top -= clipped;",
    "    } else if (clipped > 0) {",
    "        return;",
    "    }",
    "",
    "    clipped = ClipCoordToRange(&dstRectLocal.bottom, 0, g_zVideo_PrimarySurfaceState.height);",
    "    if (clipped < 0) {",
    "        return;",
    "    }",
    "    if (clipped > 0) {",
    "        srcRectLocal.bottom -= clipped;",
    "    }",
    "",
    "    IDirectDrawSurface3 *const primarySurface = g_zVideo_PrimarySurfaceState.surf;",
    "    if (primarySurface == 0) {",
    "        return;",
    "    }",
    "",
    "    const int wasLocked = g_zVideo_PrimarySurfaceState.locked;",
    "    if (wasLocked != 0) {",
    "        zVideo_dd::UnlockSurfaceState(&g_zVideo_PrimarySurfaceState);",
    "    }",
    "",
    "    const DWORD bltFlags = DDBLT_WAIT | DDBLT_KEYSRCOVERRIDE |",
    "                           ((srcImage->formatFlagsPacked & 0x02u) != 0 ? 0x8000u : 0);",
    "    zVideo_DirectDrawSurface3VtblPartial *const vtable = primarySurface->lpVtbl;",
    "    const HRESULT hresult =",
    "        vtable->Blt(primarySurface, (RECT *)&dstRectLocal, srcImage->surface,",
    "                    (RECT *)&srcRectLocal, bltFlags, 0);",
    "",
    "    if (wasLocked != 0) {",
    "        zVideo_dd::LockSurfaceState(&g_zVideo_PrimarySurfaceState);",
    "    }",
    "",
    "    if (hresult != DD_OK) {",
    "        zVideo_dd::ReportError((int)hresult,",
    "                               \"D:\\\\Proj\\\\GameZRecoil\\\\zVideo\\\\zvid_buff.c\", 0x150);",
    "    }",
    "}",
    "} // namespace zVideo_buff",
    "",
    "namespace zVid_Image {",
    "// Reimplements 0x48f500: zVid_Image::BlitToActiveTarget",
    "RECOIL_NOINLINE void RECOIL_FASTCALL BlitToActiveTarget(zVidImagePartial *image, int dstX,",
    "                                                        int dstY, int clipFlags,",
    "                                                        zVidRect32 *srcRect) {",
    "    if (image->surface != 0 && zRndr::g_frameBuffer == zVideo::GetPrimarySurfacePixels()) {",
    "        zVideo_buff::BltSourceToPrimaryClipped(image, dstX, dstY, clipFlags & 0xffff, srcRect);",
    "        return;",
    "    }",
    "",
    "    g_zVideo_pfnBltSourceToPrimary(image, dstX, dstY, clipFlags, srcRect);",
    "}",
    "} // namespace zVid_Image"
