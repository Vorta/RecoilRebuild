{
  "name": "zloc_format_message",
  "description": "zLoc FormatMessageA wrapper with CRLF trimming and copy-out.",
  "source_filename": "zLoc_FormatMessage.cpp",
  "source": [
    "#define RECOIL_CDECL __cdecl",
    "",
    "typedef void *HMODULE;",
    "typedef void *HLOCAL;",
    "typedef unsigned int DWORD;",
    "",
    "#define FORMAT_MESSAGE_ALLOCATE_BUFFER 0x00000100",
    "#define FORMAT_MESSAGE_FROM_HMODULE    0x00000800",
    "",
    "extern HMODULE g_zLoc_MessagesDllHandle;",
    "extern \"C\" __declspec(dllimport) DWORD __stdcall FormatMessageA(DWORD dwFlags, const void *lpSource, DWORD dwMessageId, DWORD dwLanguageId, char *lpBuffer, DWORD nSize, char **Arguments);",
    "extern \"C\" __declspec(dllimport) HLOCAL __stdcall LocalFree(HLOCAL hMem);",
    "extern \"C\" __declspec(dllimport) char *__cdecl strncpy(char *dest, const char *source, unsigned int count);",
    "",
    "namespace zLoc {",
    "// Reimplements 0x4a5b60: zLoc::FormatMessage",
    "unsigned int RECOIL_CDECL FormatMessage(char *outBuffer, int maxChars, unsigned int messageId, ...) {",
    "    char *arguments = (char *)(&messageId + 1);",
    "    HLOCAL sourceHandle = 0;",
    "    const unsigned int result = ::FormatMessageA(",
    "        FORMAT_MESSAGE_ALLOCATE_BUFFER | FORMAT_MESSAGE_FROM_HMODULE,",
    "        g_zLoc_MessagesDllHandle,",
    "        messageId,",
    "        0,",
    "        (char *)&sourceHandle,",
    "        (DWORD)maxChars,",
    "        (char **)&arguments);",
    "",
    "    char *source = (char *)sourceHandle;",
    "    if (source != 0) {",
    "        if ((int)result > 2 && source[result - 2] == '\\r') {",
    "            *(source + result - 2) = '\\0';",
    "        }",
    "    }",
    "",
    "    source = (char *)sourceHandle;",
    "    if (source != 0) {",
    "        strncpy(outBuffer, source, (unsigned int)maxChars);",
    "        ::LocalFree(sourceHandle);",
    "    }",
    "",
    "    return result;",
    "}",
    "}"
  ],
