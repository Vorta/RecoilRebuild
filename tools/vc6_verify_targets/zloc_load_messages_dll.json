  "description": "zLoc messages DLL loader and ZLocGetID resolver.",
  "source_filename": "zLoc_LoadMessagesDll.cpp",
  "source": [
    "#include \"GameZRecoil/zLoc/zLoc.h\"",
    "",
    "namespace zLoc {",
    "// Reimplements 0x4a5ad0: zLoc::LoadMessagesDll",
    "int RECOIL_FASTCALL LoadMessagesDll(const char *dllPath) {",
    "    int result = 0;",
    "    HMODULE const module = LoadLibraryA(dllPath);",
    "    g_zLoc_MessagesDllHandle = module;",
    "    if (module != 0) {",
    "        result = 1;",
    "        g_zLoc_GetIdProc =",
    "            (unsigned int(RECOIL_CDECL *)(const char *))GetProcAddress(module, \"ZLocGetID\");",
    "    }",
    "    return result;",
    "}",
    "}"
  ],
