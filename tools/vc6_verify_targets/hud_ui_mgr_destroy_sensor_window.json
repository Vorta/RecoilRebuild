{
  "name": "hud_ui_mgr_destroy_sensor_window",
  "description": "HudUiMgr sensor FMV window teardown.",
  "source_filename": "HudUiMgr_DestroySensorWindow.cpp",
  "source": [
    "struct zFMV_Playback {",
    "    void StopAndClose();",
    "    void Destructor();",
    "};",
    "",
    "struct CWnd {",
    "    virtual int DestroyWindow();",
    "};",
    "",
    "extern zFMV_Playback *g_HudUiSensorWindowPlayback;",
    "extern CWnd g_HudUiSensorWindow;",
    "",
    "namespace HudUiMgr {",
    "// Reimplements 0x413730: HudUiMgr::DestroySensorWindow",
    "void DestroySensorWindow() {",
    "    zFMV_Playback *playback = g_HudUiSensorWindowPlayback;",
    "    if (playback == 0) {",
    "        return;",
    "    }",
    "",
    "    playback->StopAndClose();",
    "",
    "    playback = g_HudUiSensorWindowPlayback;",
    "    if (playback != 0) {",
    "        playback->Destructor();",
    "        ::operator delete(playback);",
    "    }",
    "",
    "    g_HudUiSensorWindowPlayback = 0;",
    "    g_HudUiSensorWindow.CWnd::DestroyWindow();",
    "}",
    "}"
  ],
  "compiler_flags": [
    "/nologo",
