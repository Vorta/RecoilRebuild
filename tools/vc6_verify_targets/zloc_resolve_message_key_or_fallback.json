  "description": "zLoc message key fallback resolver.",
  "source_filename": "zLoc_ResolveMessageKeyOrFallback.cpp",
  "source": [
    "#define RECOIL_FASTCALL __fastcall",
    "",
    "namespace zLoc {",
    "unsigned int RECOIL_FASTCALL GetMessageId(const char *key);",
    "char *RECOIL_FASTCALL GetMessageString(unsigned int messageId);",
    "",
    "// Reimplements 0x4a5b40: zLoc::ResolveMessageKeyOrFallback",
    "char *RECOIL_FASTCALL ResolveMessageKeyOrFallback(const char *key) {",
    "    const unsigned int messageId = GetMessageId(key);",
    "    if (messageId != 0) {",
    "        return GetMessageString(messageId);",
    "    }",
    "",
    "    return (char *)key;",
    "}",
    "}"
  ],
