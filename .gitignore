# RecoilRebuild public source-only ignore policy.
#
# Keep reconstructed source, tools, tests, progress docs, and verification
# manifests public. Keep original/proprietary binaries, extracted payloads,
# local SDK/toolchain mirrors, and generated build output local.

# Local/private original inputs and extracted assets
support/
img/
resources/raw/
*.bndb
*.bnpm
*.idb
*.i64
*.nrg
*.iso
*.rar
*.7z
*.zip
*.zbd

# Build output and generated verification artifacts
build/
artifacts/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
MCP/
_scratch/

# Native/compiler/linker output
*.aps
*.binlog
*.cache
*.cod
*.coverage
*.coveragexml
*.dll
*.exe
*.exp
*.iobj
*.ilk
*.ipdb
*.lib
*.map
*.meta
*.ncb
*.obj
*.opendb
*.opensdf
*.pch
*.pdb
*.pgc
*.pgd
*.plg
*.res
*.rsp
!Directory.Build.rsp
*.sbr
*.sdf
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj

# Test and coverage output
TestResults/
[Tt]est[Rr]esult*/
coverage*.json
coverage*.xml
coverage*.info

# Visual Studio and IDE state
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.vcxproj.user
*.code-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.localhistory/
.history/
.vshistory/

# Legacy Visual Studio workspace/project side files
*.dsw
*.dsp
*.opt
*.vbw
*.vbp
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
MigrationBackup/

# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# AI/local assistant state
.claude/
.cursor/
.agent/claims/
AGENTS.md
**/AGENTS.md

# OS/editor temporary files
Thumbs.db
Desktop.ini
~$*
*~
*.swp
*.swo

# Tools are not tracked
/tools/
/tests/tools/
/temp/
